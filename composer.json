{
  "name": "monkeyscloud/monkeyslegion-database",
  "description": "High-performance PDO connection management with read/write splitting, connection pooling, and multi-driver support (MySQL, PostgreSQL, SQLite).",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "authors": [
    {
      "name": "MonkeysCloud",
      "email": "jorge@monkeys.cloud"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-pdo": "*",
    "psr/simple-cache": "^3.0",
    "psr/log": "^3.0",
    "monkeyscloud/monkeyslegion-cli": "^2.0"
  },
  "suggest": {
    "ext-pdo_mysql": "Required for MySQL/MariaDB connections",
    "ext-pdo_pgsql": "Required for PostgreSQL connections",
    "ext-pdo_sqlite": "Required for SQLite connections",
    "monkeyscloud/monkeyslegion-cache": "For advanced caching features (CacheManagerBridge)"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Database\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Database\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "2.0.x-dev"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^12.3",
    "phpstan/phpstan": "^2.1"
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "phpstan": "phpstan analyse src --level=9",
    "quality": [
      "@phpstan",
      "@test"
    ]
  }
}
